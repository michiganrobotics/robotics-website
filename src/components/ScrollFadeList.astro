---
// ScrollFadeList.astro - List with scroll-triggered fade-in animation
// On mobile, collapses after 10 items with a "See more" toggle
---

<div class="scroll-fade-wrapper">
  <ul class="not-prose grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3 mt-4 mb-2 text-sm list-disc pl-6 scroll-fade-list items-start">
    <slot />
  </ul>
  <button class="scroll-fade-toggle md:hidden text-sm font-semibold underline cursor-pointer mb-2 hover:decoration-maize transition-colors" type="button">See more</button>
</div>

<style is:global>
.scroll-fade-list li {
  opacity: 0;
  transform: translateY(8px);
  transition: opacity 0.6s ease, transform 0.6s ease;
  display: list-item;
  line-height: 1.4;
  margin-bottom: 0.25rem;
  align-self: start;
}

@media (max-width: 767px) {
  .scroll-fade-list.collapsed li:nth-child(n+11) {
    display: none !important;
  }
}

.scroll-fade-toggle {
  display: none;
}

@media (max-width: 767px) {
  .scroll-fade-wrapper:has(.collapsed) .scroll-fade-toggle {
    display: inline-block;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const wrappers = document.querySelectorAll('.scroll-fade-wrapper');
  if (!wrappers.length) return;

  wrappers.forEach(wrapper => {
    const list = wrapper.querySelector<HTMLUListElement>('.scroll-fade-list');
    const toggle = wrapper.querySelector<HTMLButtonElement>('.scroll-fade-toggle');
    if (!list || !toggle) return;

    const items = list.querySelectorAll<HTMLLIElement>('li');

    if (items.length > 10) {
      list.classList.add('collapsed');
    }

    toggle.addEventListener('click', function() {
      list.classList.remove('collapsed');
      toggle.style.display = 'none';
      items.forEach((item, index) => {
        if (index >= 10) {
          setTimeout(() => {
            item.style.opacity = '1';
            item.style.transform = 'translateY(0)';
          }, (index - 10) * 50);
        }
      });
    });

    const isCollapsed = list.classList.contains('collapsed');
    const visibleCount = isCollapsed && window.innerWidth < 768 ? 10 : items.length;

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          const currentItems = list.querySelectorAll<HTMLLIElement>('li');
          currentItems.forEach((item, index) => {
            if (index < visibleCount) {
              setTimeout(() => {
                item.style.opacity = '1';
                item.style.transform = 'translateY(0)';
              }, index * 50);
            }
          });
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    observer.observe(list);
  });
});
</script>
