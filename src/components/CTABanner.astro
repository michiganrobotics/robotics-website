---
import { Icon } from 'astro-icon/components';

interface Props {
	/** Headline text */
	heading: string;
	/** Supporting line under the heading */
	body?: string;
	/** Button label */
	ctaLabel: string;
	/** Button destination */
	ctaHref: string;
	/** Small kicker label above the heading */
	kicker?: string;
	/** Open the link in a new tab */
	external?: boolean;
	/**
	 * Date the banner should STOP showing, as YYYY-MM-DD (local time). The banner
	 * is hidden from the start of this day, so the last day it appears is the day
	 * before. With nightly builds, the build in the early hours of this date drops
	 * it. A client-side check also hides it as a safety net between builds.
	 */
	expires: string;
}

const { heading, body, ctaLabel, ctaHref, kicker, external = false, expires } = Astro.props;

// Build-time guard: hidden from midnight at the start of the expires day (local)
const expiryDate = new Date(`${expires}T00:00:00`);
const expired = Date.now() >= expiryDate.getTime();
---

{!expired && (
	<section
		data-cta-banner
		data-expires={expiryDate.toISOString()}
		class="cta-banner group/cta relative z-0 bg-[var(--bg-page-light)] text-umichblue dark:bg-[var(--bg-page-dark)] dark:text-neutral-50"
	>
		<!-- Soft shadow at the top edge so the banner reads as emerging from under the video -->
		<div class="absolute inset-x-0 top-0 h-3 pointer-events-none bg-gradient-to-b from-black/20 to-transparent" aria-hidden="true"></div>

		<div class="relative max-w-7xl mx-auto px-6 md:px-16 pt-5 md:pt-6 pb-7 md:pb-8 flex flex-col sm:flex-row sm:items-center gap-4 sm:gap-8">
			<div class="flex-1 min-w-0">
				{kicker && (
					<p class="text-xs md:text-sm font-bold tracking-[0.18em] uppercase text-umichblue/80 dark:text-maize mb-1">{kicker}</p>
				)}
				<p class="font-roboto-condensed font-bold text-xl md:text-2xl leading-tight">{heading}</p>
				{body && <p class="text-sm md:text-base text-umichblue/80 dark:text-neutral-300 mt-1" set:html={body} />}
			</div>

			<a
				href={ctaHref}
				target={external ? '_blank' : undefined}
				rel={external ? 'noopener noreferrer' : undefined}
				class="relative inline-flex items-center gap-2 bg-umichblue text-neutral-50 dark:bg-maize dark:text-black px-5 sm:px-7 py-2.5 sm:py-3.5 rounded-md shadow-md hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-200 no-underline font-semibold shrink-0"
			>
				{ctaLabel}
				<Icon name="mdi:arrow-right" class="w-4 h-4 flex-shrink-0 transition-transform duration-200 group-hover/cta:translate-x-1" />
			</a>
		</div>

		<!-- Tear-off tab fringe: maize tabs separated by thin slits along the bottom -->
		<div
			class="absolute inset-x-0 bottom-0 h-1 pointer-events-none dark:opacity-70 bg-[repeating-linear-gradient(90deg,var(--color-maize)_0_24px,transparent_24px_38px)]"
			aria-hidden="true"
		></div>
	</section>
)}

<style>
	/* Slide the banner down out from under the video on load. The hero sits at a
	   higher z-index, so while the banner is translated up it stays hidden behind
	   the video, then emerges from its bottom edge. `both` keeps it tucked away
	   during the start delay so there's no flash before it animates. */
	@keyframes cta-emerge {
		from { transform: translateY(-100%); }
		to { transform: translateY(0); }
	}
	.cta-banner {
		animation: cta-emerge 0.7s cubic-bezier(0.22, 1, 0.36, 1) 1s both;
	}
	@media (prefers-reduced-motion: reduce) {
		.cta-banner { animation: none; }
	}
</style>

<script>
	// Safety net: hide the banner client-side if it has expired since the last build.
	document.querySelectorAll<HTMLElement>('[data-cta-banner]').forEach((el) => {
		const expires = el.dataset.expires;
		if (expires && Date.now() >= new Date(expires).getTime()) {
			el.remove();
		}
	});
</script>
