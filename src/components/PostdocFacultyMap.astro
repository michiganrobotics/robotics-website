L551,29ZM571,27L548,27L571,27ZM778,31L753,27L766,24L778,31ZM258,29L248,33L231,27L243,24L258,29ZM310,19L328,21L286,30L291,32L276,38L251,38L257,33L264,35L256,32L264,30L259,27L273,26L246,23L310,19ZM425,18L442,20L411,22L466,24L444,27L451,27L445,31L449,36L440,37L446,44L431,49L440,54L429,52L427,55L438,55L389,68L380,83L366,81L355,71L350,63L359,56L348,57L349,53L357,54L345,51L348,48L341,42L310,39L302,36L315,35L296,33L333,22L425,18Z";

