---

<div class="postdoc-map not-prose my-6">
  <h3 class="text-lg font-semibold mb-2 text-arboretumBlue dark:text-maize">Postdoc & faculty placements</h3>
  <svg viewBox="0 0 1000 415" xmlns="http://www.w3.org/2000/svg" class="hidden lg:block h-auto w-full" role="img" aria-label="World map showing postdoc and faculty placements of Michigan Robotics graduates">
    <title>Postdoc and faculty placements of Michigan Robotics graduates</title>
    <defs>
      <radialGradient id="pfm-originGlow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#FFCB05" stop-opacity="0.7" />
        <stop offset="100%" stop-color="#FFCB05" stop-opacity="0" />
      </radialGradient>
    </defs>

    <!-- Landmasses -->
    <path d={landPath} class="land" />

    <!-- Arcs from Michigan -->
    {arcs.map((d) => (
      <path d={d} fill="none" class="arc-line" />
    ))}

    <!-- Origin (Michigan) — rendered after arcs so arcs go behind it -->
    <circle cx={origin.x} cy={origin.y} r="10" fill="url(#pfm-originGlow)" class="origin-glow" />
    <circle cx={origin.x} cy={origin.y} r="4" class="origin-ring" />
    <circle cx={origin.x} cy={origin.y} r="3" class="origin-dot" />

    <!-- Institution dots + always-on labels (rendered first, below hover labels) -->
    {destinations.map((pt) => (
      <g class={pt.showLabel ? "always-label-group" : ""} data-inst={pt.label}>
        <circle cx={pt.x} cy={pt.y} r="2.5" class="dot" data-inst={pt.label} />
        {pt.showLabel && (
          <text
            x={pt.x + (pt.labelDx || 0)}
            y={pt.y + (pt.labelDy || 0)}
            font-size="13"
            font-family="system-ui, sans-serif"
            text-anchor={pt.labelAnchor || "start"}
            class="always-label"
          >
            {pt.label}
          </text>
        )}
      </g>
    ))}

    <!-- Hover labels (rendered last, on top of everything) -->
    {destinations.filter((pt) => !pt.showLabel).map((pt) => (
      <g class="institution-group" data-inst={pt.label}>
        <circle cx={pt.x} cy={pt.y} r="4" fill="transparent" class="hover-target" />
        <text
          x={pt.x + (pt.labelDx || 0)}
          y={pt.y + (pt.labelDy || 0)}
          font-size="13"
          font-family="system-ui, sans-serif"
          text-anchor={pt.labelAnchor || "start"}
          class="hover-label"
        >
          {pt.label}
        </text>
      </g>
    ))}
  </svg>

  <div class="lg:sr-only surface rounded-lg shadow-md p-5">
    <ul class="columns-2 gap-x-6 text-sm space-y-1.5 text-gray-700 dark:text-gray-300">
      {raw.filter(r => !r.origin).flatMap((inst) =>
        inst.listNames
          ? inst.listNames.map((n) => <li>{n}</li>)
          : [<li>{inst.name}</li>]
      )}
    </ul>
  </div>
</div>

<style is:global>
  /* Land fill */
  .postdoc-map .land {
    fill: #d1d5db;
    stroke: none;
  }

  /* Arc lines */
  .postdoc-map .arc-line {
    stroke: #00274C;
    stroke-width: 1;
    opacity: 0.15;
  }

  /* Dots */
  .postdoc-map .dot {
    fill: #00274C;
  }

  /* Labels — paint-order halo for readability */
  .postdoc-map .always-label,
  .postdoc-map .hover-label {
    fill: #1f2937;
    stroke: white;
    stroke-width: 3;
    paint-order: stroke fill;
    stroke-linejoin: round;
  }

  .postdoc-map .hover-label {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease;
  }

  .postdoc-map .institution-group:hover .hover-label {
    opacity: 1 !important;
  }

  .postdoc-map .institution-group {
    cursor: default;
  }

  /* Origin styling */
  .postdoc-map .origin-ring {
    fill: #00274C;
    opacity: 0.3;
  }

  .postdoc-map .origin-dot {
    fill: #FFCB05;
  }

  .postdoc-map .origin-label {
    fill: #00274C;
    opacity: 0.95;
  }

  /* Origin pulse animation */
  .postdoc-map .origin-glow {
    animation: pfmOriginPulse 2.5s ease-in-out infinite;
  }

  @keyframes pfmOriginPulse {
    0%, 100% {
      opacity: 0.3;
      r: 10;
    }
    50% {
      opacity: 0.6;
      r: 14;
    }
  }

  /* Dark mode */
  @media (prefers-color-scheme: dark) {
    .postdoc-map .land {
      fill: #374151;
    }

    .postdoc-map .arc-line {
      stroke: #FFCB05;
      opacity: 0.12;
    }

    .postdoc-map .dot {
      fill: white;
    }

    .postdoc-map .always-label,
    .postdoc-map .hover-label {
      fill: #f3f4f6;
      stroke: #00274C;
      stroke-width: 4;
    }

    .postdoc-map .origin-ring {
      fill: white;
    }

    .postdoc-map .origin-dot {
      fill: #FFCB05;
    }

    .postdoc-map .origin-label {
      fill: white;
    }
  }

  .postdoc-map .hover-label.cycle-visible {
    opacity: 1 !important;
  }

  .postdoc-map .always-label {
    transition: opacity 1.2s ease 0.3s;
  }

  .postdoc-map .always-label.label-hidden {
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .postdoc-map .dot.cycle-active {
    fill: #FFCB05 !important;
  }

  .postdoc-map .cycle-glow {
    fill: #FFCB05;
    animation: pfmDotPulse 1.5s ease-out infinite;
  }

  @keyframes pfmDotPulse {
    0% { r: 2.5; opacity: 0.6; }
    100% { r: 10; opacity: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .postdoc-map .origin-glow {
      animation: none;
    }
  }
</style>

<script>
  function initMapCycle() {
    const map = document.querySelector('.postdoc-map');
    if (!map) return;

    const groups = Array.from(map.querySelectorAll('.institution-group'));
    if (groups.length === 0) return;

    let currentIndex = 0;
    let intervalId: ReturnType<typeof setInterval> | null = null;
    let isHovering = false;

    // Map of hover labels that conflict with always-on labels
    const labelConflicts: Record<string, string[]> = {
      'Cleveland Clinic': ['Harvard / MIT / Northeastern'],
      'HSS (NYC)': ['Harvard / MIT / Northeastern'],
      'Penn State': ['Harvard / MIT / Northeastern'],
      'Syracuse': ['Harvard / MIT / Northeastern'],
      'Naval Academy': ['Harvard / MIT / Northeastern'],
      'Vanderbilt': ['Georgia Tech'],
      'Arizona State': ['UC Berkeley'],
      'Oklahoma State': ['Stanford', 'UC Berkeley'],
      'Maine': ['Harvard / MIT / Northeastern'],
      'Rochester': ['Harvard / MIT / Northeastern'],
      'SUNY Buffalo': ['Harvard / MIT / Northeastern'],
    };

    function hideConflicting(inst: string) {
      const conflicts = labelConflicts[inst];
      if (!conflicts) return;
      conflicts.forEach(c => {
        map.querySelector(`.always-label-group[data-inst="${c}"] .always-label`)?.classList.add('label-hidden');
      });
    }

    function showConflicting(inst: string) {
      const conflicts = labelConflicts[inst];
      if (!conflicts) return;
      conflicts.forEach(c => {
        map.querySelector(`.always-label-group[data-inst="${c}"] .always-label`)?.classList.remove('label-hidden');
      });
    }

    function showNext() {
      // Remove previous
      groups.forEach(g => {
        g.querySelector('.hover-label')?.classList.remove('cycle-visible');
        const inst = g.getAttribute('data-inst');
        if (inst) {
          showConflicting(inst);
          const dot = map!.querySelector(`.dot[data-inst="${inst}"]`);
          dot?.classList.remove('cycle-active');
          dot?.parentElement?.querySelector('.cycle-glow')?.remove();
        }
      });
      // Show current
      const group = groups[currentIndex];
      group.querySelector('.hover-label')?.classList.add('cycle-visible');
      const inst = group.getAttribute('data-inst');
      if (inst) {
        hideConflicting(inst);
        const dot = map.querySelector(`.dot[data-inst="${inst}"]`) as SVGCircleElement;
        if (dot) {
          dot.classList.add('cycle-active');
          const glow = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          glow.setAttribute('cx', dot.getAttribute('cx')!);
          glow.setAttribute('cy', dot.getAttribute('cy')!);
          glow.setAttribute('r', '2.5');
          glow.classList.add('cycle-glow');
          dot.parentElement?.insertBefore(glow, dot);
        }
      }
      currentIndex = (currentIndex + 1) % groups.length;
    }

    function startCycle() {
      if (intervalId || isHovering) return;
      showNext();
      intervalId = setInterval(showNext, 2000);
    }

    function stopCycle() {
      if (intervalId) {
        clearInterval(intervalId);
        intervalId = null;
      }
      groups.forEach(g => {
        g.querySelector('.hover-label')?.classList.remove('cycle-visible');
        const inst = g.getAttribute('data-inst');
        if (inst) {
          showConflicting(inst);
          const dot = map!.querySelector(`.dot[data-inst="${inst}"]`);
          dot?.classList.remove('cycle-active');
          dot?.parentElement?.querySelector('.cycle-glow')?.remove();
        }
      });
    }

    // Stop cycling when user hovers any institution group; highlight hovered dot
    groups.forEach(g => {
      g.addEventListener('mouseenter', () => {
        isHovering = true;
        stopCycle();
        const inst = g.getAttribute('data-inst');
        if (inst) {
          map!.querySelector(`.dot[data-inst="${inst}"]`)?.classList.add('cycle-active');
          hideConflicting(inst);
        }
      });
      g.addEventListener('mouseleave', () => {
        const inst = g.getAttribute('data-inst');
        if (inst) {
          map!.querySelector(`.dot[data-inst="${inst}"]`)?.classList.remove('cycle-active');
          showConflicting(inst);
        }
        isHovering = false;
        setTimeout(() => { if (!isHovering) startCycle(); }, 3000);
      });
    });

    // Also stop on hover of always-visible label dots and highlight them
    map.querySelectorAll('.always-label-group').forEach(g => {
      g.addEventListener('mouseenter', () => {
        isHovering = true;
        stopCycle();
        g.querySelector('.dot')?.classList.add('cycle-active');
      });
      g.addEventListener('mouseleave', () => {
        g.querySelector('.dot')?.classList.remove('cycle-active');
        isHovering = false;
        setTimeout(() => { if (!isHovering) startCycle(); }, 3000);
      });
    });

    // Respect reduced motion
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    startCycle();
  }

  // Run on page load and Astro page transitions
  initMapCycle();
  document.addEventListener('astro:page-load', initMapCycle);
</script>
