---
// PostdocFacultyMap.astro — SVG world map showing postdoc & faculty positions

interface Institution {
  name: string;
  label: string;
  lat: number;
  lon: number;
  showLabel?: boolean;
  origin?: boolean;
  labelDx?: number;
  labelDy?: number;
  labelAnchor?: string;
  listNames?: string[];
}

function toSvg(lon: number, lat: number) {
  return {
    x: Math.round((lon + 180) / 360 * 1000),
    y: Math.round((90 - lat) / 180 * 500),
  };
}

function arcPath(x1: number, y1: number, x2: number, y2: number) {
  const dx = x2 - x1;
  const dy = y2 - y1;
  const dist = Math.sqrt(dx * dx + dy * dy);
  const mx = (x1 + x2) / 2;
  const my = (y1 + y2) / 2;
  const offset = Math.min(dist * 0.25, 60);
  return `M${x1},${y1} Q${mx},${my - offset} ${x2},${y2}`;
}

