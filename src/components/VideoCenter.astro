---
import { YouTube } from 'astro-embed';

interface Props {
  url: string;
  caption?: string;
  transcript?: string;
  class?: string;
}

const { url, caption, transcript, class: className } = Astro.props;

// Extract video ID from various YouTube URL formats or use as-is if it's just an ID
function getVideoId(input: string): string {
  // Already just an ID
  if (/^[\w-]{11}$/.test(input)) return input;

  // Full URL formats
  const patterns = [
    /(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/|youtube\.com\/shorts\/)([^&?\s]+)/,
  ];
  for (const pattern of patterns) {
    const match = input.match(pattern);
    if (match) return match[1];
  }
  return input;
}

const videoId = getVideoId(url);

// Check if maxresdefault exists at build time, fall back to hqdefault
async function getPosterUrl(id: string): Promise<string> {
  const maxRes = `https://i.ytimg.com/vi/${id}/maxresdefault.jpg`;
  try {
    const response = await fetch(maxRes, { method: 'HEAD' });
    if (response.ok) return maxRes;
  } catch {}
  return `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
}

const posterUrl = await getPosterUrl(videoId);
---
<div class="block w-full mb-8">
  <figure class={`${className}`}>
    <div class="aspect-video flex items-center justify-center">
      <YouTube
        id={videoId}
        class="w-full h-full"
        playsInline={true}
        poster={posterUrl}
        params={{
          rel: 0,
          modestbranding: 1,
          playsinline: 1,
          controls: 1
        }}
      />
    </div>
    {(caption || transcript) && (
      <figcaption class="mt-4 text-[0.875em] leading-[1.4285714] text-gray-600 dark:text-gray-200">
        {caption && <span set:html={caption} />}
        {transcript && (
          <details class="video-transcript mt-2">
            <summary class="cursor-pointer select-none flex items-center gap-1 w-fit hover:text-gray-900 dark:hover:text-white transition-colors">
              <span class="transcript-icon inline-flex items-center justify-center w-4 h-4 text-xs font-bold border border-current rounded-full leading-none">+</span>
              Transcript
            </summary>
            <div class="mt-2 pl-5 whitespace-pre-line" set:html={transcript} />
          </details>
        )}
      </figcaption>
    )}
  </figure>
</div>

<style>
.aspect-video lite-youtube{
  max-width:none;
}

.video-transcript summary {
  list-style: none;
}
.video-transcript summary::-webkit-details-marker {
  display: none;
}
.video-transcript[open] .transcript-icon {
  font-size: 0;
}
.video-transcript[open] .transcript-icon::before {
  content: '\2212';
  font-size: 0.75rem;
}
</style>

