---
import { YouTube } from 'astro-embed';

interface Props {
  url: string;
  caption?: string;
  transcript?: string;
  class?: string;
}

const { url, caption, transcript, class: className } = Astro.props;
---
<figure class={`block w-full aspect-video mb-8 lg:float-right lg:w-[400px] lg:ml-8 ${className}`}>
  <YouTube 
  id={url} 
  class="w-full h-full" 
  playsInline={true} 
  params={{
      rel: 0,
      modestbranding: 1,
      playsinline: 1,
      controls: 1
    }}
  />
  {(caption || transcript) && (
    <figcaption class="mt-3.5 text-[0.875em] leading-[1.4285714] text-gray-600 dark:text-gray-200">
      {caption && <span>{caption}</span>}
      {transcript && (
        <details class="video-transcript mt-2">
          <summary class="cursor-pointer select-none flex items-center gap-1 w-fit hover:text-gray-900 dark:hover:text-white transition-colors">
            <span class="transcript-icon inline-flex items-center justify-center w-4 h-4 text-xs font-bold border border-current rounded-full leading-none">+</span>
            Transcript
          </summary>
          <div class="mt-2 pl-5 whitespace-pre-line" set:html={transcript} />
        </details>
      )}
    </figcaption>
  )}
</figure>

<style>
.video-transcript summary {
  list-style: none;
}
.video-transcript summary::-webkit-details-marker {
  display: none;
}
.video-transcript[open] .transcript-icon {
  font-size: 0;
}
.video-transcript[open] .transcript-icon::before {
  content: '\2212';
  font-size: 0.75rem;
}
</style>