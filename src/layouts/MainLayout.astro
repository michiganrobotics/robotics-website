---
import '../styles/global.css';
import SiteNav from "../components/SiteNav.astro"; 
import SiteFooter from "../components/SiteFooter.astro";
import { SEO } from 'astro-seo';


interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { 
	title,
	description = "Work together. Create smart machines. Serve society.",
	image = "/social/og-default.jpg"  // default fallback image
} = Astro.props;

const siteUrl = "https://robotics.umich.edu";

---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="icon" type="image/svg+xml" href="/favicon.ico" />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<slot name="head"/>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "EducationalOrganization",
			"@id": `${siteUrl}/#organization`,
			"name": "University of Michigan Robotics Department",
			"alternateName": ["Michigan Robotics", "U-M Robotics", "UMich Robotics", "UMRobotics"],
			"url": siteUrl,
			"logo": `${siteUrl}/robotics-og-logo.png`,
			"image": `${siteUrl}/robotics-og-logo.png`,
			"foundingDate": "2022",
			"parentOrganization": {
				"@type": "CollegeOrUniversity",
				"name": "University of Michigan College of Engineering",
				"url": "https://engin.umich.edu",
				"parentOrganization": {
					"@type": "CollegeOrUniversity",
					"name": "University of Michigan",
					"url": "https://umich.edu"
				}
			},
			"description": "The Robotics Department at the University of Michigan College of Engineering: working together to create smart machines and serve society.",
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "2505 Hayward Street",
				"addressLocality": "Ann Arbor",
				"addressRegion": "MI",
				"postalCode": "48109",
				"addressCountry": "US"
			},
			"areaServed": "Ann Arbor, Michigan",
			"sameAs": [
				"https://www.instagram.com/umrobotics/",
				"https://www.linkedin.com/company/university-of-michigan-robotics/",
				"https://github.com/michiganrobotics/",
				"https://www.youtube.com/channel/UC-WH2n-SkB166pUq5o5ULUg",
				"https://www.twitter.com/umrobotics",
				"https://www.wikidata.org/wiki/Q138804945"
			]
		})} />
		<SEO
			title={title}
			description={description}
			openGraph={{
				basic: {
					title,
					type: "website",
					image: `${siteUrl}${image}`,
				},
				optional: {
					description,
					siteName: "Michigan Robotics",
					locale: "en_US",
				},
				image: {
					alt: "Michigan Robotics",
					width: 1200,
					height: 630,
					type: "image/jpeg",
				}
			}}
			twitter={{
				card: "summary_large_image",
				site: "@UMRobotics",
				title,
				description,
				image: `${siteUrl}${image}`,
			}}
			extend={{
				meta: [
					{
						name: 'keywords',
						content: 'robotics, michigan, engineering, research, education'
					}
				]
			}}
		/>
		<link 
			rel="preload" 
			href="/fonts/fonts.css" 
			as="style" 
			onload="this.onload=null;this.rel='stylesheet'"
			crossorigin="anonymous"
		>
		<script is:inline>
			document.documentElement.classList.add('is-loading');
		  </script>
		<noscript>
			<link rel="stylesheet" href="/fonts/fonts.css">
		</noscript>
	</head>
	<body class="page-bg">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-umichblue focus:text-white focus:rounded focus:outline-none focus:ring-2 focus:ring-maize">
			Skip to main content
		</a>
		<SiteNav></SiteNav>
		<slot name="breadcrumbs" />
		<main id="main-content" class="m-auto mb-20">
			<slot></slot>
		</main>
		<SiteFooter></SiteFooter>
	</body>
	<script is:inline>
		window.addEventListener('load', () => {
		  document.documentElement.classList.remove('is-loading');
		});
	  </script>
		<script 
			data-goatcounter="https://robotics-umich-edu.goatcounter.com/count"
			async 
			src="//gc.zgo.at/count.js"
			fetchpriority="low"
		></script>
</html>