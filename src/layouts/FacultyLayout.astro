---
import Layout from './MainLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { Image, getImage } from 'astro:assets';
import { getProfileImagePath, getAwards } from '../lib/googleSheets';
import { Icon } from 'astro-icon/components';
import Link from '../components/Link.astro';

const { faculty } = Astro.props;

// Get focus areas matching this faculty member
const allFocusAreas = await getCollection('focusAreas');
const facultyFocusAreaSlugs = faculty.focusAreas
  ? faculty.focusAreas.split(',').map((a: string) => a.trim()).filter(Boolean)
  : [];
const facultyFocusAreas = allFocusAreas.filter(area => facultyFocusAreaSlugs.includes(area.id));

// Get all profile images with absolute paths
const images = import.meta.glob<any>('/src/images/profile-images/*.{png,jpg,jpeg,gif,webp}');
const robotProfile = await import('../images/profile-images/robot-profile.jpg');

// Get profile image
let profileImage: any = robotProfile; // Default to robot profile
let imagePath;

try {
  imagePath = getProfileImagePath(faculty);
  const imageLoader = images[imagePath];
  if (imageLoader) {
    profileImage = await imageLoader();
  }
} catch (error) {
  console.error('Error in image processing:', {
    faculty: faculty.fullName,
    imagePath,
    error: error instanceof Error ? error.message : String(error)
  });
}

// Fetch all news posts with tag of faculty member's full name
const allNamedPosts = await getCollection('news', ({ data }) => {
  return data.tags?.includes(faculty.fullName);
});

// Fetch college news posts with tag of faculty member's full name
const collegeNewsPosts = await getCollection('collegeNews', ({ data }) => {
  return data.tags?.includes(faculty.fullName);
});

// Format college news posts to match structure
const formattedCollegeNews = collegeNewsPosts.map(item => ({
  id: `college/${item.id}`,
  collection: 'collegeNews' as const,
  data: {
    title: item.data.title,
    date: item.data.date,
    image: item.data.image,
    link: item.data.link
  }
}));

// Helper function to determine if a post is college news
function isCollegeNews(post: any) {
  return post.collection === 'collegeNews';
}

// Helper function to get post link
function getPostLink(post: any) {
  if (isCollegeNews(post)) {
    return post.data.link;
  }
  return `/news/${new Date(post.data.date).getFullYear()}/${post.id.split('/')[1]}/`;
}

// Combine and sort all posts by date
const relatedPosts = [...allNamedPosts, ...formattedCollegeNews]
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Fetch awards for this faculty member
const allAwards = await getAwards();
const facultyAwards = allAwards.filter(award => {
  const recipients = award.awardRecipient.split('\n').map((r: string) => r.trim());
  return recipients.includes(faculty.fullName);
}).sort((a, b) => parseInt(b.awardYear) - parseInt(a.awardYear));

// Structured data for Person
const siteUrl = "https://robotics.umich.edu";
const sameAs = [faculty.googleScholar, faculty.labWebsite, faculty.website].filter(Boolean);
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": faculty.fullName,
  "jobTitle": faculty.title,
  "url": `${siteUrl}/people/faculty/${faculty.slug}/`,
  "image": profileImage?.default?.src ? `${siteUrl}${profileImage.default.src}` : undefined,
  ...(faculty.email && { "email": `mailto:${faculty.email}` }),
  "worksFor": {
    "@type": "Organization",
    "name": "Michigan Robotics",
    "url": siteUrl
  },
  ...(sameAs.length > 0 && { "sameAs": sameAs })
};
---

<Layout
  title={faculty?.preferredName && faculty?.lastName ? `${faculty.preferredName} ${faculty.lastName} | Robotics Faculty Profile` : 'Faculty Profile' }
  image={profileImage?.default?.src || robotProfile.default.src}
  description={`Learn more about Michigan Robotics faculty member ${faculty.fullName}.`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>
  <Breadcrumbs slot="breadcrumbs" />
  {faculty ? (
    <div class="mt-4 max-w-4xl mx-auto py-8 px-4 font-roboto text-umichblue dark:text-neutral-50 bg-white dark:bg-umichblue">
      <div class="grid md:grid-cols-3 gap-8">
        <!-- Profile Photo -->
        <div class="md:col-span-1">
          <Image
            src={profileImage?.default || robotProfile.default}
            alt={faculty.fullName}
            width={732}
            height={488}
            class="w-full rounded-sm shadow-lg"
          />
        </div>
        
        <!-- Faculty Details -->
        <div class="md:col-span-2">
          <h1 class="text-4xl font-bold mb-2 font-roboto-condensed">{faculty.fullName}</h1>
          <div class="mb-4">
            <p class="text-xl text-arboretumBlue dark:text-taubmanTeal">
              {faculty.title}, {faculty.department1}{faculty.department2 && ` and ${faculty.department2}`}
            </p>
            {(faculty.additionalTitle1 || faculty.additionalTitle2) && (
              <p class="text-lg text-gray-600 dark:text-gray-300 italic font-roboto-condensed">
                {faculty.additionalTitle1}{faculty.additionalTitle2 && <><br />{faculty.additionalTitle2}</>}
              </p>
            )}
          </div>

          <!-- Contact Info -->
          <div class="mb-6 space-y-4">
            {faculty.email && (
              <p class="flex flex-col">
                <span class="font-bold text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">Email</span> 
                <a href={`mailto:${faculty.email}`} class="hover:underline text-lg">
                  {faculty.email}
                </a>
              </p>
            )}
            {faculty.office && (
              <p class="flex flex-col">
                <span class="font-bold text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">Office</span>
                <span class="text-lg">{faculty.office}</span>
              </p>
            )}
            {faculty.researchInterests && (
              <p class="flex flex-col">
                <span class="font-bold text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">Research Interests</span>
                <span class="text-lg">{faculty.researchInterests}</span>
              </p>
            )}
            {facultyFocusAreas.length > 0 && (
              <p class="flex flex-col">
                <span class="font-bold text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">Research Focus Areas</span>
                <span class="text-md">{facultyFocusAreas.map((area, i) => (
                  <>{i > 0 && ', '}<Link href={`/research/focus-areas/${area.id}/`} class="hover:underline dark:text-maize">{area.data.title}</Link></>
                ))}</span>
              </p>
            )}
          </div>

          <!-- Additional Links -->
          <div class="space-y-4">
            {faculty.googleScholar && (
              <p class="flex flex-col">
                <span class="font-bold text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">Google Scholar</span>
                <a href={faculty.googleScholar} target="_blank" rel="noopener noreferrer" class="hover:underline text-lg dark:text-maize">
                  View Profile
                </a>
              </p>
            )}
            {faculty.labWebsite && (
              <p class="flex flex-col">
                <span class="font-bold text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">Lab Website</span>
                <a href={faculty.labWebsite} target="_blank" rel="noopener noreferrer" class="hover:underline text-lg dark:text-maize">
                  Visit Lab Website
                </a>
              </p>
            )}
            {faculty.website && (
              <p class="flex flex-col">
                <span class="font-bold text-xs uppercase tracking-wider text-gray-600 dark:text-gray-300">Personal Website</span>
                <a href={faculty.website} target="_blank" rel="noopener noreferrer" class="hover:underline text-lg dark:text-maize">
                  Visit Personal Website
                </a>
              </p>
            )}
          </div>
        </div>
      </div>
      
      {/* Related News Section */}
      {relatedPosts.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold mb-4 font-roboto-condensed dark:text-neutral-50">Related news</h2>
          <div class="relative scroll-fade-container" role="region" aria-label="Related news articles">
            <div class="related-news-scroll flex overflow-x-auto pb-4 gap-4 scrollbar-hide sm:grid sm:grid-cols-2 lg:grid-cols-3 sm:overflow-visible sm:pb-0" data-scroll-container tabindex="0">
              {relatedPosts.map(async (post) => {
                const postImage = post.data.image?.src ? await getImage({
                  src: post.data.image.src,
                  width: 450,
                  height: 300,
                }) : null;

                return (
                <a
                  href={getPostLink(post)}
                  target={isCollegeNews(post) ? '_blank' : undefined}
                  rel={isCollegeNews(post) ? 'noopener noreferrer' : undefined}
                  class="no-underline group block bg-(--bg-surface-light) dark:bg-(--bg-page-dark) text-gray-700 dark:text-neutral-100 card-base card-hover flex-none w-65 sm:w-auto"
                >
                  <div class="aspect-video overflow-hidden rounded-t-sm not-prose">
                    {postImage ? (
                      <Image
                        src={postImage.src}
                        alt={post.data.image?.alt || post.data.title}
                        width={450}
                        height={300}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <img
                        src="/social/og-default.jpg"
                        alt={post.data.title}
                        width={450}
                        height={300}
                        class="w-full h-full object-cover"
                      />
                    )}
                  </div>
                  <div class="p-3">
                    <p class="text-base font-roboto font-bold leading-snug group-hover:underline group-hover:decoration-maize group-hover:decoration-2 group-hover:underline-offset-2">
                      {post.data.title}
                      {isCollegeNews(post) && <><Icon name="mdi:open-in-new" class="inline w-4 h-4 ml-1" aria-hidden="true" /><span class="sr-only">(opens in a new tab)</span></>}
                    </p>
                    <p class="text-xs text-gray-600 dark:text-gray-300 mt-1 mb-0">
                      {new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </p>
                  </div>
                </a>
                );
              })}
            </div>
          </div>
        </div>
      )}

      {/* Honors and Awards Section */}
      {facultyAwards.length > 0 && (
        <div class="mt-12">
          <h2 class="text-2xl font-bold mb-4 font-roboto-condensed dark:text-neutral-50">Honors and awards</h2>
          <div class="space-y-0">
            {facultyAwards.map(award => (
              <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 py-3 border-b border-gray-200 dark:border-gray-700">
                <span class="text-sm font-medium text-gray-700 dark:text-gray-300 sm:w-16 shrink-0">{award.awardYear}</span>
                <div>
                  <span class="font-medium">{award.award}</span>
                  {award.awardOrganization && (
                    <span class="text-sm text-gray-600 dark:text-gray-300"> &mdash; {award.awardOrganization}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  ) : (
    <p class="text-center text-angellHallAsh dark:text-burtonTowerBeige">Error loading faculty data...</p>
  )}
</Layout>

<style>
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  @media (max-width: 639px) {
    .scroll-fade-container { overflow: clip; }
    .scroll-fade-container::before,
    .scroll-fade-container::after {
      content: '';
      position: absolute;
      top: 0;
      bottom: 0;
      width: 40px;
      pointer-events: none;
      z-index: 1;
      opacity: 0;
      transition: opacity 0.3s ease;
    }
    .scroll-fade-container::before {
      left: 0;
      background: linear-gradient(to right, white, transparent);
    }
    .scroll-fade-container::after {
      right: 0;
      background: linear-gradient(to left, white, transparent);
    }
    @media (prefers-color-scheme: dark) {
      .scroll-fade-container::before { background: linear-gradient(to right, var(--color-umichblue), transparent); }
      .scroll-fade-container::after { background: linear-gradient(to left, var(--color-umichblue), transparent); }
    }
    .scroll-fade-container.fade-left::before { opacity: 1; }
    .scroll-fade-container.fade-right::after { opacity: 1; }
  }
</style>

<script>
  document.querySelectorAll('[data-scroll-container]').forEach((container) => {
    const parent = container.closest('.scroll-fade-container') as HTMLElement | null;
    const el = container as HTMLElement;

    const updateFades = () => {
      if (!parent) return;
      const atStart = el.scrollLeft <= 0;
      const atEnd = Math.ceil(el.scrollLeft + el.clientWidth) >= el.scrollWidth;
      const hasOverflow = el.scrollWidth > el.clientWidth;
      parent.classList.toggle('fade-left', hasOverflow && !atStart);
      parent.classList.toggle('fade-right', hasOverflow && !atEnd);
    };

    el.addEventListener('scroll', updateFades);
    window.addEventListener('resize', updateFades);
    updateFades();
  });
</script>
