---
import Layout from '../../../../layouts/MainLayout.astro';
import News from '../../../../components/templates/News.astro';
import RelatedNews from '../../../../components/RelatedNews.astro';
import { getCollection, render } from 'astro:content';
import { components } from '../../../../components/components';

export async function getStaticPaths() {
  const newsEntries = await getCollection('news');

  return newsEntries.map(entry => {
    const year = entry.data.date.split('-')[0];
    const slug = entry.id.split('/')[1];
    const entryId = entry.id;
    const entryTags = entry.data.tags || [];

    let tagGroups: { tag: string; articles: { title: string; date: string; slug: string; image?: { src: any; alt: string } }[] }[] = [];

    if (entryTags.length > 0) {
      const tagCounts = entryTags.map(tag => {
        const matches = newsEntries.filter(other =>
          other.id !== entryId && other.data.tags?.includes(tag)
        );
        return { tag, count: matches.length, matches };
      });

      tagCounts.sort((a, b) => b.count - a.count);
      const tagsWithMatches = tagCounts.filter(t => t.count > 0).slice(0, 3);

      // Deduplicate articles across groups so the same article doesn't appear twice
      const seen = new Set<string>();
      for (const t of tagsWithMatches) {
        const articles = t.matches
          .filter(m => !seen.has(m.id))
          .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
          .slice(0, 3)
          .map(a => {
            seen.add(a.id);
            return {
              title: a.data.title,
              date: a.data.date,
              slug: a.id.split('/')[1],
              image: a.data.image,
            };
          });

        if (articles.length > 0) {
          tagGroups.push({ tag: t.tag, articles });
        }
      }
    }

    return {
      params: { year, slug },
      props: { entry, tagGroups }
    };
  });
}

const { entry, tagGroups } = Astro.props;
const { Content } = await render(entry);

// Get all focus areas to map categories to titles
const focusAreas = await getCollection('focusAreas');
const categoryTitles = Object.fromEntries(
  focusAreas.map(area => [area.id, area.data.title.toLowerCase()])
);
// Create excerpt for SEO description
const description = entry.data.seoDescription || entry.data.excerpt || `${entry.data.title}`;

// Generate OG image URL
const ogImage = `/_generated-og/${entry.data.date.split('-')[0]}-${entry.id.split('/')[1]}.png`;

// Structured data for NewsArticle
const siteUrl = "https://robotics.umich.edu";
const articleUrl = `${siteUrl}/news/${entry.data.date.split('-')[0]}/${entry.id.split('/')[1]}/`;
const newsArticleSchema = {
  "@context": "https://schema.org",
  "@type": "NewsArticle",
  "headline": entry.data.title,
  "datePublished": entry.data.date,
  "description": description,
  "image": `${siteUrl}${ogImage}`,
  "url": articleUrl,
  ...(entry.data.author && {
    "author": {
      "@type": "Person",
      "name": entry.data.author
    }
  }),
  "publisher": {
    "@type": "Organization",
    "name": "Michigan Robotics",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/robotics-og-logo.png`
    }
  }
};

// Transform entry data to match Single template's expected node structure
const node = {
  title: entry.data.title,
  date: entry.data.date,
  author: entry.data.author,
  categories: entry.data.categories ? {
    nodes: entry.data.categories.map(cat => ({
      name: cat,
      prettyName: categoryTitles[cat] || cat.replace(/-/g, ' '),
      uri: `/news/${cat}/`
    }))
  } : null
};
---

<Layout
  title={entry.data.title}
  description={description}
  image={ogImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(newsArticleSchema)} />
  </Fragment>
  <News node={node}>
    <Content slot="content" components={components}/>
  </News>
  {tagGroups.length > 0 && (
    <RelatedNews tagGroups={tagGroups} />
  )}
</Layout>
