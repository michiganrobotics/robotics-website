---
import Layout from '../../../layouts/MainLayout.astro';
import { getFacultyData, getProfileImagePath } from '../../../lib/googleSheets';
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import PageTitle from "../../../components/PageTitle.astro";
import PersonCard from "../../../components/PersonCard.astro";

const facultyMembers = await getFacultyData();

// Get all profile images
const images = import.meta.glob('/src/images/profile-images/*.{png,jpg,jpeg,gif,webp}');
const robotProfile = await import('../../../images/profile-images/robot-profile.jpg');

// Process image paths
const profileImages = await Promise.all(
  facultyMembers.map(async (faculty) => {
    const imagePath = getProfileImagePath(faculty);
    const imageLoader = images[imagePath];

    if (imageLoader) {
      const image = await imageLoader();
      return image.default;
    }

    return robotProfile.default;
  })
);

---

<Layout title="Faculty Directory | Michigan Robotics" description="University of Michigan Robotics faculty members who are leading the field of robotics.">
<Breadcrumbs slot="breadcrumbs" />
<PageTitle title="Faculty Directory" />
    <div class="mx-2 m-auto mb-4 md:mx-12">
      <div class="not-prose px-2 pt-10" role="search" aria-label="Faculty directory">
        <input
          type="text"
          id="facultySearch"
          placeholder="Search by name, title, or research interests..."
          aria-label="Search faculty"
          class="search-bar"
        />
        <div class="sr-only" aria-live="polite" aria-atomic="true" id="searchStatus"></div>
      </div>
      <div class="relative mb-16">
       <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 2xl:grid-cols-6 gap-6 pt-6 px-2">
          {facultyMembers.map((faculty, index) => (
            <div
              class="faculty-card h-full"
              data-name={`${faculty.preferredName} ${faculty.lastName}`.toLowerCase()}
              data-title={faculty.title.toLowerCase()}
              data-department={`${faculty.department1 || ''} ${faculty.department2 || ''}`.toLowerCase()}
              data-department-display={[faculty.department1, faculty.department2].filter(Boolean).join(' and ')}
              data-research={faculty.researchInterests?.toLowerCase() || ''}
              data-research-display={faculty.researchInterests || ''}
            >
              <PersonCard
                name={`${faculty.preferredName} ${faculty.lastName}`}
                href={`/people/faculty/${faculty.slug}/`}
                image={profileImages[index]}
                title={faculty.title}
                additionalTitle={faculty.additionalTitle1}
                loading={index < 12 ? 'eager' : 'lazy'}
              >
                <p class="match-context hidden mt-2 pt-2 border-t border-arboretumBlue/10 dark:border-arboretumBlue/20 text-xs text-gray-600 dark:text-gray-300 line-clamp-3"></p>
              </PersonCard>
            </div>
          ))}
        </div>
      </div>
    </div>
</Layout>

<script>
  const searchInput = document.getElementById('facultySearch') as HTMLInputElement;
  const facultyCards = document.querySelectorAll('.faculty-card');
  const searchStatus = document.getElementById('searchStatus');

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  let debounceTimer: ReturnType<typeof setTimeout>;

  searchInput.addEventListener('input', (e) => {
    const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
    let visibleCount = 0;

    facultyCards.forEach((card) => {
      const el = card as HTMLElement;
      const contextEl = el.querySelector('.match-context') as HTMLElement;

      if (!searchTerm) {
        el.style.display = '';
        contextEl.classList.add('hidden');
        contextEl.textContent = '';
        visibleCount++;
        return;
      }

      const name = el.dataset.name || '';
      const title = el.dataset.title || '';
      const dept = el.dataset.department || '';
      const research = el.dataset.research || '';

      // Find what matched (skip name/title since those are already visible)
      let matchField = '';
      let matchDisplay = '';
      if (name.includes(searchTerm) || title.includes(searchTerm)) {
        // Name or title matched — no extra context needed
      } else if (dept.includes(searchTerm)) {
        matchField = 'Dept';
        matchDisplay = el.dataset.departmentDisplay || '';
      } else if (research.includes(searchTerm)) {
        matchField = 'Research';
        matchDisplay = el.dataset.researchDisplay || '';
      }

      const matches = name.includes(searchTerm) || title.includes(searchTerm) ||
        dept.includes(searchTerm) || research.includes(searchTerm);

      el.style.display = matches ? '' : 'none';
      if (matches) visibleCount++;

      if (matches && matchDisplay) {
        const idx = matchDisplay.toLowerCase().indexOf(searchTerm);
        let html = '';
        if (idx >= 0) {
          const snippetRadius = 40;
          const start = Math.max(0, idx - snippetRadius);
          const end = Math.min(matchDisplay.length, idx + searchTerm.length + snippetRadius);
          const prefix = start > 0 ? '...' : '';
          const suffix = end < matchDisplay.length ? '...' : '';

          const before = escapeHtml(matchDisplay.slice(start, idx));
          const matched = escapeHtml(matchDisplay.slice(idx, idx + searchTerm.length));
          const after = escapeHtml(matchDisplay.slice(idx + searchTerm.length, end));

          html = `<span class="font-semibold text-gray-600 dark:text-gray-300">${escapeHtml(matchField)}:</span> ${prefix}${before}<mark class="bg-maize text-umichblue rounded-sm px-0.5">${matched}</mark>${after}${suffix}`;
        } else {
          html = `<span class="font-semibold text-gray-600 dark:text-gray-300">${escapeHtml(matchField)}:</span> ${escapeHtml(matchDisplay)}`;
        }
        contextEl.innerHTML = html;
        contextEl.classList.remove('hidden');
      } else {
        contextEl.classList.add('hidden');
        contextEl.textContent = '';
      }
    });

    // Announce results to screen readers (debounced)
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      if (searchStatus) {
        if (!searchTerm) {
          searchStatus.textContent = '';
        } else {
          searchStatus.textContent = `${visibleCount} faculty member${visibleCount !== 1 ? 's' : ''} found`;
        }
      }
    }, 500);
  });
</script>
