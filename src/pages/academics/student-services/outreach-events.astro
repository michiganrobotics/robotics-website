---
import Layout from '../../../layouts/MainLayout.astro';
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import PageTitle from "../../../components/PageTitle.astro";

import { getRoboticsOutreachEvents } from '../../../lib/googleSheets';

const outreachEventsData = await getRoboticsOutreachEvents();

// Helper function to convert URLs in text to clickable links
function linkifyText(text: string): string {
  if (!text) return '';
  const urlRegex = /(https?:\/\/[^\s<>)\]]+)/g;
  return text.replace(urlRegex, '<a href="$1" target="_blank" rel="noopener noreferrer" class="text-umichblue dark:text-[#7eb8da] underline hover:no-underline" onclick="event.stopPropagation()">$1</a>');
}
---

<Layout title="Current Robotics Outreach Events | Michigan Robotics" description="Current robotics outreach events available for students.">
    <Breadcrumbs slot="breadcrumbs" />
    <PageTitle title="Current Robotics Outreach Events" />
      <div class="prose dark:prose-invert max-w-6xl w-11/12 mx-auto mt-4 mb-4">
          <p class="mb-4">
            Current outreach events intended for Robotics students. These events are submitted by robotics faculty members and they may be looking for volunteers.
          </p>
          <p class="mb-4">
            Search to find events that match your interests by <strong>event name</strong>, <strong>event description</strong>, <strong>location</strong>, or <strong>point of contact</strong>.
          </p>
          <div class="relative">
              <div class="mb-4">
                <input type="text" id="searchInput" placeholder="Search projects..." 
                  class="search-bar"
                />
              </div>
              <div class="overflow-x-auto shadow-md">
                <table class="text-sm text-left">
                  <thead class="text-xs uppercase page-bg">
                    <tr>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="name">
                        Event Name
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="description">
                        Event Description
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="startDate">
                        Start Date
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="endDate">
                        End Date
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="location">
                        Location
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="pointOfContact">
                        Event Point of Contact
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="lookingForVolunteers">
                        Looking for Volunteers?
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="numberOfVolunteers">
                        Number of Volunteer(s)
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r">
                        Volunteer Tasks
                      </th>
                      <th scope="col" class="px-4 py-3">
                        How to sign up as a Volunteer
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {outreachEventsData.map((event) => (
                      <tr class="bg-[var(--bg-undersurface-light)] dark:bg-[var(--bg-undersurface-dark)] border-b hover:bg-[var(--bg-surface-hover)] dark:hover:bg-[var(--bg-surface-hover-dark)]">
                        <th scope="row" class="px-6 py-4 font-medium border-r align-top">
                          {event.eventName}
                        </th>
                        <td class="px-6 py-4 border-r align-top max-w-md">
                          <div class="desc-wrapper">
                            <div class="desc-content line-clamp-3">
                              <span>{event.eventDescription}</span>
                            </div>
                            <span class="click-more">(click to expand)</span>
                          </div>
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.startDate}
                          {event.startTime}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.endDate}
                          {event.endTime}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.eventLocation}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          <div class="font-medium">{event.eventContactName}</div>
                          {event.eventContactEmail && (
                            <div class="text-sm">
                              <a href={`mailto:${event.eventContactEmail}`} class="underline hover:text-umichblue dark:hover:text-gray-300">
                                {event.eventContactEmail}
                              </a>
                            </div>
                            )}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.lookingForVolunteer}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.numberOfVolunteers}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.volunteerTasks}
                        </td>
                        <td class="px-6 py-4 align-top">
                          <span set:html={linkifyText(event.howToSignUpVolunteer || '')} />
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <script>
            // Check if description cells are truncated and show/hide "click to expand"
            function checkTruncation() {
              document.querySelectorAll('.desc-wrapper').forEach(wrapper => {
                const content = wrapper.querySelector('.desc-content') as HTMLElement;
                const clickMore = wrapper.querySelector('.click-more') as HTMLElement;
                if (!content || !clickMore) return;

                const isExpanded = wrapper.classList.contains('expanded');

                if (isExpanded) {
                  // When expanded, hide click-more but keep pointer cursor
                  clickMore.style.display = 'none';
                  (wrapper as HTMLElement).style.cursor = 'pointer';
                } else {
                  // When collapsed, check if content is truncated
                  const isTruncated = content.scrollHeight > content.clientHeight;
                  if (isTruncated) {
                    clickMore.style.display = 'block';
                    (wrapper as HTMLElement).style.cursor = 'pointer';
                  } else {
                    clickMore.style.display = 'none';
                    (wrapper as HTMLElement).style.cursor = 'default';
                  }
                }
              });
            }

            // Add click handlers to toggle expanded state
            document.querySelectorAll('.desc-wrapper').forEach(wrapper => {
              wrapper.addEventListener('click', (e) => {
                // Don't toggle if clicking a link
                if ((e.target as HTMLElement).tagName === 'A') return;
                wrapper.classList.toggle('expanded');
                checkTruncation();
              });
            });

            // Run on load and window resize
            checkTruncation();
            window.addEventListener('resize', checkTruncation);

            // Search functionality
            const searchInput = document.getElementById('searchInput');
            const tableRows = document.querySelectorAll('tbody tr');
            
            if (searchInput) {
              searchInput.addEventListener('keyup', function(e) {
                if (e.target) {
                  const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
                  
                  tableRows.forEach(row => {
                    const text = row.textContent?.toLowerCase() || '';
                    if (row instanceof HTMLElement) {
                      row.style.display = text.includes(searchTerm) ? '' : 'none';
                    }
                  });
                }
              });
            }

            // Sorting functionality
            const getCellValue = (tr: HTMLElement, idx: number) => {
              const cell = tr.children[idx];
              return cell ? cell.textContent || '' : '';
            };
            
            const comparer = (idx: number, asc: boolean) => (a: HTMLElement, b: HTMLElement) => {
              const v1 = getCellValue(a, idx);
              const v2 = getCellValue(b, idx);
              return v1 !== '' && v2 !== '' && !isNaN(Number(v1)) && !isNaN(Number(v2))
                ? (asc ? 1 : -1) * (Number(v1) - Number(v2))
                : (asc ? 1 : -1) * v1.toString().localeCompare(v2);
            };
            
            document.querySelectorAll('th[data-sort]').forEach(th => {
              let asc = true;
              th.addEventListener('click', () => {
                const table = th.closest('table');
                const tbody = table?.querySelector('tbody');
                if (!tbody) return;
                
                const columnIndex = Array.from(th.parentElement?.children || []).indexOf(th);
                
                // Update sort indicators
                if (th.parentElement) {
                  th.parentElement.querySelectorAll('th').forEach(header => {
                    const span = header.querySelector('span');
                    if (span) {
                      span.textContent = '↕';
                    }
                  });
                }
                
                const span = th.querySelector('span');
                if (span) {
                  span.textContent = asc ? '↑' : '↓';
                }
                
                const rows = Array.from(tbody.querySelectorAll('tr'));
                rows.sort(comparer(columnIndex, asc))
                  .forEach(tr => tbody.appendChild(tr));
                
                asc = !asc;
              });
            });
          </script>
</Layout>
<style>
  table{
    min-width: 1750px;
  }

  .desc-wrapper {
    cursor: default;
  }

  .desc-wrapper.expanded .desc-content {
    -webkit-line-clamp: unset !important;
    line-clamp: unset !important;
    display: block;
  }

  .click-more {
    display: none;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 0.25rem;
  }
</style>