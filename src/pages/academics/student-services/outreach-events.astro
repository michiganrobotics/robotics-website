---
import Layout from '../../../layouts/MainLayout.astro';
import Breadcrumbs from "../../../components/Breadcrumbs.astro";
import PageTitle from "../../../components/PageTitle.astro";
import Button from "../../../components/Button.astro";
import Callout from "../../../components/Callout.astro";
import { Image, getImage } from 'astro:assets';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

import { getRoboticsOutreachEvents } from '../../../lib/googleSheets';

const outreachEventsData = await getRoboticsOutreachEvents();

// Pull the most recent news items tagged "outreach" to surface alongside the events table.
const allNews = await getCollection('news');
const outreachNews = allNews
  .filter((post) => post.data.tags?.some((t) => t.toLowerCase() === 'outreach'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);

const outreachNewsCards = await Promise.all(
  outreachNews.map(async (post) => {
    const slug = post.id.split('/')[1];
    const year = post.data.date.split('-')[0];
    const image = post.data.image?.src
      ? await getImage({ src: post.data.image.src, width: 540, height: 360 })
      : null;
    return {
      title: post.data.title,
      date: post.data.date,
      href: `/news/${year}/${slug}/`,
      image,
      imageAlt: post.data.image?.alt || post.data.title,
    };
  })
);

// Helper function to convert URLs in text to clickable links
function linkifyText(text: string): string {
  if (!text) return '';
  const urlRegex = /(https?:\/\/[^\s<>)\]]+)/g;
  return text.replace(urlRegex, '<a href="$1" target="_blank" rel="noopener noreferrer" class="text-umichblue dark:text-[#7eb8da] underline hover:no-underline" onclick="event.stopPropagation()">$1</a>');
}

function addPaddingToDates(date: string): string {
  if(!date) return '';
  let split = date.split('/');
  let day; let month; let year;
  if(split && split.length){
    day = split[0];
    month = split[1];
    year = split[2];
    if(!isNaN(parseInt(day))){
      if(parseInt(day)< 10){
        day = `0${day}`
      }
    }
    if(!isNaN(parseInt(month))){
      if(parseInt(month)< 10){
        month = `0${month}`
      }
    }
    return `${day}/${month}/${year}`;
  }
  else return date;
}

function formatRawTimeString(timestring: string): string{
  // This function expects the timestrings input to be of format 'HH:MM:SS AM'
  let timesection; let ampmsection;
  let level1Split = timestring.split(' ');
  if(level1Split && level1Split.length){
    timesection = level1Split[0];
    ampmsection = level1Split[1];
  }
  let level2Split;
  if(timesection && typeof timesection === 'string'){
    level2Split = timesection.split(':');
    if(level2Split && level2Split.length === 3){
      //Should return 'HH:MM AM'
      return `${level2Split[0]}:${level2Split[1]} ${ampmsection}`
    }
  }

  return timestring;
}
---

<Layout title="Current Robotics Outreach Events | Michigan Robotics" description="Current robotics outreach events available for students.">
    <Breadcrumbs slot="breadcrumbs" />
    <PageTitle title="Current Robotics Outreach Events" />
      <div class="prose dark:prose-invert max-w-6xl w-11/12 mx-auto mt-4 mb-4">
          <p class="text-xl leading-relaxed mb-4">
            Being <a href="/about/values/">enthusiastic for outreach</a> is a core Michigan Robotics value. Our outreach efforts build for and inspire the next generation of roboticists, inform policies that benefit society, and foster public understanding of where robotics is as a field. 
          </p>
          <p class="mb-4">
            Enthusiastic outreach takes many forms, from contributing open-source code to engaging at large-scale educational events, volunteering at FIRST Robotics competitions, leading activities for K-12 students, or working with <a href="/about/partnerships/">partners</a> across industry and community organizations.
          </p>
          <p class="mb-4">
            Below are current outreach events submitted by Robotics faculty, staff, and student members. If you are interested in volunteering, you can reach out through the "How to sign up as a volunteer" links provided.
          </p>
          <Callout type="info">
            <p class="m-0">Are you a student, faculty or staff looking to add an event? You can fill out <a href="https://docs.google.com/forms/d/e/1FAIpQLSf18JgbLQkLAnnd3_0zhGKAHkDpPF2zVrDImmSfkO97ftirqg/viewform">this form to add an event</a> to this table.</p>
          </Callout>
          { outreachEventsData.length ? 
          <h2>Upcoming events</h2>
          <p class="mb-4">
            Search to find events that match your interests by <strong>event name</strong>, <strong>event description</strong>, <strong>location</strong>, or <strong>point of contact</strong>.
          </p>
           <div class="relative">
              <div class="mb-4">
                <input type="text" id="searchInput" placeholder="Search events..." 
                  class="search-bar"
                />
              </div>
              <div class="overflow-x-auto shadow-md">
                <table class="text-sm text-left">
                  <thead class="text-xs uppercase page-bg">
                    <tr>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="name">
                        Event Name
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="description">
                        Event Description
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="startDate">
                        Start Date
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="endDate">
                        End Date
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="location">
                        Location
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 cursor-pointer border-r" data-sort="pointOfContact">
                        Event Point of Contact
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="lookingForVolunteers">
                        Looking for Volunteers?
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r" data-sort="numberOfVolunteers">
                        Number of Volunteer(s)
                        <span class="ml-1">↕</span>
                      </th>
                      <th scope="col" class="px-4 py-3 border-r">
                        Volunteer Tasks
                      </th>
                      <th scope="col" class="px-4 py-3 border-r">
                        How to sign up as a Volunteer
                      </th>
                      <th scope="col" class="px-4 py-3" data-sort="roboticsLabAffiliation">
                        Robotics Lab/Organization Affiliation
                        <span class="ml-1">↕</span>
                      </th>
                    </tr>
                  </thead>
                  <tbody>
                    {outreachEventsData.map((event) => (
                      <tr class="bg-[var(--bg-undersurface-light)] dark:bg-[var(--bg-undersurface-dark)] border-b hover:bg-[var(--bg-surface-hover)] dark:hover:bg-[var(--bg-surface-hover-dark)]">
                        <td scope="row" class="px-6 py-4 font-medium border-r align-top">
                          {event.eventName}
                        </td>
                        <td class="px-6 py-4 border-r align-top max-w-md">
                          <div class="desc-wrapper">
                            <div class="desc-content line-clamp-3">
                              <span>{event.eventDescription}</span>
                            </div>
                            <span class="click-more">(click to expand)</span>
                          </div>
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {addPaddingToDates(event.startDate)}
                          {formatRawTimeString(event.startTime)}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {addPaddingToDates(event.endDate)}
                          {formatRawTimeString(event.endTime)}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.eventLocation}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          <div class="font-medium">{event.eventContactName}</div>
                          {event.eventContactEmail && (
                            <div class="text-sm">
                              <a href={`mailto:${event.eventContactEmail}`} class="underline hover:text-umichblue dark:hover:text-gray-300">
                                {event.eventContactEmail}
                              </a>
                            </div>
                            )}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.lookingForVolunteer}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.numberOfVolunteers}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          {event.volunteerTasks}
                        </td>
                        <td class="px-6 py-4 border-r align-top">
                          <span set:html={linkifyText(event.howToSignUpVolunteer || '')} />
                        </td>
                        <td class="px-6 py-4 align-top">
                          {event.roboticsLabAffiliation}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div> :
            <div class="not-prose card-base surface card-padded border-l-4 border-maize my-6 flex flex-col sm:flex-row items-start gap-4">
              <div class="shrink-0 rounded-full bg-maize/20 dark:bg-maize/10 p-3">
                <Icon name="mdi:calendar-month-outline" class="w-8 h-8 text-umichblue dark:text-maize" />
              </div>
              <div>
                <h3 class="text-2xl font-roboto-condensed font-bold text-umichblue dark:text-neutral-100 mb-2">No active events right now</h3>
                <p class="text-neutral-700 dark:text-neutral-200 mb-3">More events will be posted soon.</p>
                <p class="mb-0">Considering hosting your own outreach event, or have an event to share? <a href="https://docs.google.com/forms/d/e/1FAIpQLSf18JgbLQkLAnnd3_0zhGKAHkDpPF2zVrDImmSfkO97ftirqg/viewform">Submit it through this form</a> and it will appear here.</p>
              </div>
            </div>}

            <section id="outreach-ambassador" aria-labelledby="ambassador-heading" class="card-base surface card-padded my-10">
              <h2 id="ambassador-heading">Robotics Outreach Ambassador program</h2>
              <p>The Robotics Department formally recognizes student efforts in outreach. To do so, we track outreach for which you can be awarded a special title each year, one we hope students will be proud to highlight on resumés and talk about when transitioning to the next step in your life.</p>
              <p>If a student logs eight hours of outreach in the year, from start of summer to end of winter terms, then they will be awarded the title of Robotics Outreach Ambassador for that year. Those earning this title will be announced and celebrated in the spring.</p>
              <p><strong>What counts?</strong> Any service, outreach, or community activity that supports the mission, culture, and values of the Robotics Department can be reported. We'll trust your judgment.</p>
              <p>Student contributions in outreach are instrumental to our success. We hope to adapt and build on this in the future with your continued input.</p>
              <Button href="https://docs.google.com/forms/d/e/1FAIpQLSe5XSNyGNU-1Utg1W1pV4oHdaA_40lMmN5Uz5IAqPMaJkcDBg/viewform?usp=publish-editor" text="Log your outreach hours" subtext="Currently open to graduate students only" external={true} class="w-auto!" />
            </section>

            {outreachNewsCards.length > 0 && (
              <section id="latest-outreach-news" aria-labelledby="outreach-news-heading" class="my-10 not-prose">
                <h2 id="outreach-news-heading" class="text-3xl font-roboto-condensed font-bold text-umichblue dark:text-neutral-100 mb-6">Latest outreach news</h2>
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                  {outreachNewsCards.map((article) => (
                    <a href={article.href} class="no-underline group surface card-base card-hover flex flex-col">
                      <div class="relative overflow-hidden">
                        {article.image ? (
                          <Image
                            src={article.image.src}
                            alt={article.imageAlt}
                            width={540}
                            height={360}
                            class="w-full h-48 object-cover"
                            loading="lazy"
                          />
                        ) : (
                          <img
                            src="/social/og-default.jpg"
                            alt={article.imageAlt}
                            width={540}
                            height={360}
                            class="w-full h-48 object-cover"
                            loading="lazy"
                          />
                        )}
                      </div>
                      <div class="p-4 grow flex flex-col justify-between">
                        <div>
                          <h3 class="text-lg leading-tight font-roboto font-bold text-umichblue dark:text-gray-100 mb-2 border-b-2 border-transparent group-hover:border-maize transition-all duration-300">
                            {article.title}
                          </h3>
                          <p class="text-sm font-sans text-neutral-700 dark:text-neutral-300 mb-0">
                            {new Date(article.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                          </p>
                        </div>
                      </div>
                    </a>
                  ))}
                </div>
              </section>
            )}
          </div>

          <script>
            // Check if description cells are truncated and show/hide "click to expand"
            function checkTruncation() {
              document.querySelectorAll('.desc-wrapper').forEach(wrapper => {
                const content = wrapper.querySelector('.desc-content') as HTMLElement;
                const clickMore = wrapper.querySelector('.click-more') as HTMLElement;
                if (!content || !clickMore) return;

                const isExpanded = wrapper.classList.contains('expanded');

                if (isExpanded) {
                  // When expanded, hide click-more but keep pointer cursor
                  clickMore.style.display = 'none';
                  (wrapper as HTMLElement).style.cursor = 'pointer';
                } else {
                  // When collapsed, check if content is truncated
                  const isTruncated = content.scrollHeight > content.clientHeight;
                  if (isTruncated) {
                    clickMore.style.display = 'block';
                    (wrapper as HTMLElement).style.cursor = 'pointer';
                  } else {
                    clickMore.style.display = 'none';
                    (wrapper as HTMLElement).style.cursor = 'default';
                  }
                }
              });
            }

            // Add click handlers to toggle expanded state
            document.querySelectorAll('.desc-wrapper').forEach(wrapper => {
              wrapper.addEventListener('click', (e) => {
                // Don't toggle if clicking a link
                if ((e.target as HTMLElement).tagName === 'A') return;
                wrapper.classList.toggle('expanded');
                checkTruncation();
              });
            });

            // Run on load and window resize
            checkTruncation();
            window.addEventListener('resize', checkTruncation);

            // Search functionality
            const searchInput = document.getElementById('searchInput');
            const tableRows = document.querySelectorAll('tbody tr');
            
            if (searchInput) {
              searchInput.addEventListener('keyup', function(e) {
                if (e.target) {
                  const searchTerm = (e.target as HTMLInputElement).value.toLowerCase();
                  
                  tableRows.forEach(row => {
                    const text = row.textContent?.toLowerCase() || '';
                    if (row instanceof HTMLElement) {
                      row.style.display = text.includes(searchTerm) ? '' : 'none';
                    }
                  });
                }
              });
            }

            // Sorting functionality
            const getCellValue = (tr: HTMLElement, idx: number) => {
              const cell = tr.children[idx];
              return cell ? cell.textContent || '' : '';
            };
            
            const comparer = (idx: number, asc: boolean) => (a: HTMLElement, b: HTMLElement) => {
              const v1 = getCellValue(a, idx);
              const v2 = getCellValue(b, idx);
              return v1 !== '' && v2 !== '' && !isNaN(Number(v1)) && !isNaN(Number(v2))
                ? (asc ? 1 : -1) * (Number(v1) - Number(v2))
                : (asc ? 1 : -1) * v1.toString().localeCompare(v2);
            };
            
            document.querySelectorAll('th[data-sort]').forEach(th => {
              let asc = true;
              th.addEventListener('click', () => {
                const table = th.closest('table');
                const tbody = table?.querySelector('tbody');
                if (!tbody) return;
                
                const columnIndex = Array.from(th.parentElement?.children || []).indexOf(th);
                
                // Update sort indicators
                if (th.parentElement) {
                  th.parentElement.querySelectorAll('th').forEach(header => {
                    const span = header.querySelector('span');
                    if (span) {
                      span.textContent = '↕';
                    }
                  });
                }
                
                const span = th.querySelector('span');
                if (span) {
                  span.textContent = asc ? '↑' : '↓';
                }
                
                const rows = Array.from(tbody.querySelectorAll('tr'));
                rows.sort(comparer(columnIndex, asc))
                  .forEach(tr => tbody.appendChild(tr));
                
                asc = !asc;
              });
            });
          </script>
</Layout>
<style>
  table{
    min-width: 2225px;
  }

  .desc-wrapper {
    cursor: default;
  }

  .desc-wrapper.expanded .desc-content {
    -webkit-line-clamp: unset !important;
    line-clamp: unset !important;
    display: block;
  }

  tbody tr :nth-child(2),thead tr :nth-child(2){
    word-break: break-all;
  }

  tbody tr :nth-child(3), tbody tr :nth-child(4), thead tr :nth-child(3), thead tr :nth-child(4){
    width: 150px;
    text-align: center;
  }

  tbody tr :nth-child(5), thead tr :nth-child(5) {
    width: 250px;
    text-align: center;
  }

  tbody tr :nth-child(6), thead tr :nth-child(6){
    width: 205px;
    max-width: 205px;
  }

  tbody tr :nth-child(7), thead tr :nth-child(7),tbody tr :nth-child(8), thead tr :nth-child(8){
    width: 135px;
    max-width: 135px;
    text-align: center;
  }

  tbody tr :nth-child(9), thead tr :nth-child(9){
    width: 225px;
    max-width: 225px;
  }

  tbody tr :nth-child(10), thead tr :nth-child(10){
    width: 200px;
    max-width: 200px;
    word-wrap: break-word;
  }

  tbody tr :nth-child(11), thead tr :nth-child(11){
    width: 200px;
    max-width: 200px;
    word-wrap: break-word;
  }

  .click-more {
    display: none;
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 0.25rem;
  }
</style>